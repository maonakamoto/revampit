# Production ops template — copy to .env.selfhost.local (gitignored)
#
# Hetzner Postgres 17 runs on the app box (localhost:5432 from the server).
# From your laptop, tunnel first:
#   ssh -L 15432:localhost:5432 ubuntu@167.233.22.31
#
# Then set DATABASE_URL to localhost:15432. Read the live value from the box:
#   ssh ubuntu@167.233.22.31 'grep ^DATABASE_URL= /opt/revampit/app/.env'

DATABASE_URL=postgresql://revampit:YOUR_PROD_PASSWORD@localhost:15432/revampit
AUTH_SECRET=your-production-auth-secret
NEXTAUTH_URL=https://revampit.orangecat.ch
NEXT_PUBLIC_SITE_URL=https://revampit.orangecat.ch

# Payrexx — see docs/operations/PAYREXX_SETUP.md (leave unset until go-live)
# PAYREXX_INSTANCE=
# PAYREXX_API_SECRET=
# PAYREXX_WEBHOOK_SECRET=
