{
    "kind": "collectionType",
    "collectionName": "static_pages",
    "info": {
        "singularName": "static-page",
        "pluralName": "static-pages",
        "displayName": "Static Page",
        "description": "Content for static pages like About, Contact, etc."
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true,
            "maxLength": 255
        },
        "slug": {
            "type": "uid",
            "targetField": "title",
            "required": true,
            "unique": true
        },
        "page_key": {
            "type": "string",
            "required": true,
            "unique": true,
            "maxLength": 100
        },
        "sections": {
            "type": "dynamiczone",
            "components": [
                "layout.hero",
                "layout.text-with-image",
                "layout.impact-section",
                "layout.stats-section",
                "layout.cta"
            ]
        },
        "page_type": {
            "type": "enumeration",
            "enum": ["about", "contact", "services", "projects", "general"],
            "default": "general",
            "required": true
        },
        "seo_title": {
            "type": "string",
            "maxLength": 60
        },
        "seo_description": {
            "type": "text",
            "maxLength": 160
        },
        "show_in_navigation": {
            "type": "boolean",
            "default": false
        }
    }
}
