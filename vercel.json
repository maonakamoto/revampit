{
  "version": 2,
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "preview": true
    }
  },
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=31536000"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "alias": ["revampit.vercel.app"],
  "crons": [
    {
      "path": "/api/cron/close-decisions",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/close-it-hilfe-requests",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/prune-audit-log",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/wake-recurring-tasks",
      "schedule": "0 7 * * *"
    }
  ]
}