{
  "name": "revampit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "WATCHPACK_POLLING=1 next dev",
    "dev:cms": "echo 'CMS disabled'",
    "dev:full": "npm run medusa:start && npm run dev",
    "dev:medusa": "npm run medusa:start",
    "dev:shop": "concurrently \"npm run dev\" \"npm run dev:medusa\"",
    "d": "npm run dev:full",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down db",
    "services:up": "docker compose up -d db medusa_db medusa_redis meilisearch",
    "services:down": "docker compose down",
    "start:all": "npm run medusa:setup && npm run dev",
    "stop:all": "npm run services:down",
    "setup": "npm run db:up && sleep 5",
    "setup-admins": "npx tsx scripts/setup-all-admins.ts",
    "reset": "npm run services:down && docker compose down -v && npm run setup",
    "build": "next build && next-sitemap",
    "build:cms": "echo 'CMS disabled'",
    "start": "next start",
    "start:cms": "echo 'CMS disabled'",
    "medusa:start": "./scripts/start-medusa.sh",
    "medusa:up": "docker compose -f docker-compose.medusa.yml up -d medusa_db medusa_redis meilisearch",
    "medusa:bootstrap": "node scripts/medusa-bootstrap.mjs",
    "medusa:bootstrap:9001": "MEDUSA_BACKEND_URL=http://localhost:9001 node scripts/medusa-bootstrap.mjs",
    "medusa:setup": "npm run medusa:start && node scripts/medusa-bootstrap.mjs",
    "dev:all": "npm run medusa:setup && npm run dev",
    "medusa:setup:9001": "npm run medusa:up && MEDUSA_BACKEND_URL=http://localhost:9001 node scripts/medusa-bootstrap.mjs",
    "medusa:dev": "cd medusa-backend && npm run dev",
    "medusa:dev:9001": "cd medusa-backend && MEDUSA_PORT=9001 npm run dev",
    "medusa:down": "docker compose -f docker-compose.medusa.yml down",
    "medusa:logs": "docker compose -f docker-compose.medusa.yml logs -f medusa",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "deploy": "./deploy.sh",
    "setup-deploy": "./setup-deploy-keybind.sh"
  },
  "dependencies": {
    "@auth/pg-adapter": "^1.11.1",
    "@headlessui/react": "^2.1.0",
    "@heroicons/react": "^2.1.1",
    "@medusajs/js-sdk": "^2.12.0",
    "@stripe/stripe-js": "^8.6.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.87.1",
    "@tanstack/react-query": "^5.90.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/nodemailer": "^7.0.1",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "cookie": "^1.0.2",
    "csv-parse": "^6.1.0",
    "framer-motion": "^12.23.25",
    "gray-matter": "^4.0.3",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.488.0",
    "next": "^14.2.35",
    "next-auth": "^5.0.0-beta.30",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.2.1",
    "node-html-parser": "^7.0.1",
    "nodemailer": "^7.0.11",
    "pg": "^8.16.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "redis": "^5.10.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^20.1.0",
    "tailwind-merge": "^3.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie": "^0.6.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.24",
    "@types/pg": "^8.15.5",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.0",
    "critters": "^0.0.25",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.1.3",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.35",
    "postcss-import": "^16.1.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  }
}
